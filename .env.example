PORT=3000
TRACKER_BASE_URL=https://tracker.example/forum
TRACKER_DEFAULT_SOURCE_URL=
TRACKER_TEXT_SEARCH_PATH=tracker.php
# App sign-in uses the same credentials below (single user mode).
TRACKER_USERNAME=your_username
TRACKER_PASSWORD=your_password
TRACKER_DIRECT_DOWNLOAD_DIR=/volume1/Downloads
APP_UPDATE_SCRIPT_PATH=./update.sh
# Optional explicit version, e.g. 1.1.2603111805 (UTC+4).
APP_VERSION=
TRACKER_MAX_RELEASES=80
TRACKER_HARD_MAX_RELEASES=700
TRACKER_CONCURRENCY=4
TRACKER_REQUEST_TIMEOUT_MS=25000
TRACKER_CHECK_RELEASE_URL=
TRACKER_CHECK_COLLECTION_URL=
TRACKER_CHECK_MAX_RELEASES=5
